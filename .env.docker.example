# BonusTrack — Docker Compose Variablen
# Diese Datei zu .env kopieren und befüllen. NIEMALS committen.
#
# Auf Hostinger Docker Manager:
#   Tab "Umgebung" → diese Keys eintragen, dann "Bereitstellen".

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=bonustrack
POSTGRES_DB=bonustrack
# starkes Passwort, min. 24 Zeichen (für den DB-User im internen Netz)
POSTGRES_PASSWORD=__BITTE_AENDERN__

# ─── App ─────────────────────────────────────────────────────────────────────
# JWT-Signing-Key — min. 32 Zeichen, z.B. via `openssl rand -base64 48`
JWT_SECRET=__BITTE_AENDERN__
JWT_EXPIRES_IN=8h

# FriStD-Bau Partner-API-Key
PARTNER_API_KEY=__BITTE_AENDERN__

# Optional: Resend für Mail-Versand (leer lassen wenn nicht genutzt)
RESEND_API_KEY=

# ─── Domain / Traefik ────────────────────────────────────────────────────────
# Die öffentliche URL der App (ohne https://)
APP_DOMAIN=fb-bonus.fristd-bau.com

# Name des externen Docker-Netzwerks, in dem Traefik läuft.
# Üblich: "proxy", "traefik", "web"  — anpassen, falls deins anders heißt.
TRAEFIK_NETWORK=proxy

# Name des Let's-Encrypt-Resolvers in deiner traefik.yml
# (üblich: "letsencrypt" oder "myresolver" — bei `traefik.toml` prüfen)
TRAEFIK_CERT_RESOLVER=letsencrypt

# Namen der Traefik-EntryPoints (Default: web=80, websecure=443)
TRAEFIK_HTTP_ENTRYPOINT=web
TRAEFIK_HTTPS_ENTRYPOINT=websecure

# ─── Initialer Stammdaten-Sync ───────────────────────────────────────────────
# Beim ersten Deploy auf "true" setzen, damit
# scripts/update-stammdaten-2026.ts einmal läuft (Franz, Phillip, Olaf,
# Dritan, Lukas, Mark-Leon). Danach wieder auf "false" stellen.
RUN_STAMMDATEN_UPDATE=false
