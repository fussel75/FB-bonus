# BonusTrack — Docker Compose Variablen
# Diese Datei zu .env kopieren und befüllen. NIEMALS committen.
#
# Auf Hostinger Docker Manager:
#   Tab "Umgebung" → diese Keys eintragen, dann "Bereitstellen".

# Datenbank-Passwort — starkes Passwort, z.B. `openssl rand -base64 24`
POSTGRES_PASSWORD=__BITTE_AENDERN__

# JWT-Signing-Key — min. 32 Zeichen, z.B. `openssl rand -base64 48`
JWT_SECRET=__BITTE_AENDERN__

# FriStD-Bau Partner-API-Key
PARTNER_API_KEY=__BITTE_AENDERN__

# Optional: Resend für Mail-Versand (leer lassen wenn nicht genutzt)
RESEND_API_KEY=

# Beim ERSTEN Deploy auf "true" setzen, danach wieder auf "false":
#   Führt scripts/update-stammdaten-2026.ts einmal aus (Franz, Phillip,
#   Olaf, Dritan, Lukas, Mark-Leon).
RUN_STAMMDATEN_UPDATE=true
