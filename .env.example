# Datenbank
DATABASE_URL="postgresql://user:password@localhost:5432/bonustrack"

# JWT
JWT_SECRET="bitte-aendern-mindestens-32-zeichen-lang"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000
NODE_ENV=development

# Externe API (wird auch in DB-Konfiguration gespeichert, hier als Fallback)
EXTERNAL_API_URL=""
